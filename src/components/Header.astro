---
import { nav } from '../data/site';
import { getCollection } from 'astro:content';
const path = Astro.url.pathname;
const isCurrent = (p: string) => path === p || path.startsWith(p + '/');
const projects = (await getCollection('research'))
  .filter((p) => p.data.published)
  .sort((a, b) => a.data.order - b.data.order);
---
<header class="site">
  <div class="wrap nav">
    <a class="brand" href="/">
      <img src="/logo-mark.png" alt="" width="18" height="24" />
      Blue Leaf Labs
    </a>
    <button class="menu-btn" aria-expanded="false" aria-controls="nav-links">Menu</button>
    <nav class="nav-links" id="nav-links" aria-label="Primary">
      {nav.map((s) => (
        s.path === '/research' && projects.length > 0 ? (
          <span class="nav-item has-flyout">
            <a href={s.path} aria-current={isCurrent(s.path) ? 'page' : undefined}>{s.label}</a>
            <span class="flyout">
              {projects.map((p) => (<a href={`/research/${p.id}`}>{p.data.title}</a>))}
              <a class="flyout-all" href="/research">All research →</a>
            </span>
          </span>
        ) : (
          <a href={s.path} aria-current={isCurrent(s.path) ? 'page' : undefined}>{s.label}</a>
        )
      ))}
      <a class="nav-cta" href="/get-involved">Get involved</a>
    </nav>
  </div>
</header>
<script>
  const btn = document.querySelector('.menu-btn');
  const links = document.getElementById('nav-links');
  btn?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
