---
import Base from '../layouts/Base.astro';
---
<Base title="Accessibility Statement | Blue Leaf Labs" description="Accessibility Statement for Blue Leaf Labs.">
  <div class="wrap page-intro">
    <span class="eyebrow">Legal</span>
    <h1>Accessibility Statement</h1>
  </div>
  <section>
    <div class="wrap">
      <div class="held">
        <strong>Action needed:</strong> paste your existing Accessibility Statement text here (copy it from the current
        Wix site, or edit this file / the CMS "Pages" entry). The URL <code>/accessibility-statement</code> is preserved,
        so all existing links and footer references keep working.
      </div>
      <div class="prose" style="margin-top:1.5rem">
        <p>&mdash; Accessibility Statement content goes here &mdash;</p>
      </div>
    </div>
  </section>
</Base>
