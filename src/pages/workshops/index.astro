---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const items = (await getCollection('workshops'))
  .filter((w) => w.data.published)
  .sort((a, b) => a.data.order - b.data.order);
---
<Base title="Watt Workshops | Blue Leaf Labs" description="Watt Workshops: hands-on sessions that teach real technical methods.">
  <div class="wrap page-intro">
    <h1>Watt Workshops</h1>
    <p>Hands-on sessions that make technical work approachable, built to teach real methods, not just concepts.</p>
  </div>
  <section>
    <div class="wrap">
      {items.length === 0 ? (
        <div class="ledger"><div class="lrow"><div class="lcell body" style="border-left:none">The first sessions are being scheduled.</div></div></div>
      ) : (
        <div class="ledger">
          {items.map((w) => (
            <a class="lrow tight" href={`/workshops/${w.id}`}>
              <div class="lcell label"><span class="lname">{w.data.title}</span></div>
              <div class="lcell body"><p class="ldesc" style="margin:0">{w.data.summary}</p></div>
              <div class="lcell meta"><span class="post-meta">{w.data.level ?? ''}</span></div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
