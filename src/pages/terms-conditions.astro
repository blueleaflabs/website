---
import Base from '../layouts/Base.astro';
---
<Base title="Terms & Conditions | Blue Leaf Labs" description="Terms & Conditions for Blue Leaf Labs.">
  <div class="wrap page-intro">
    <span class="eyebrow">Legal</span>
    <h1>Terms & Conditions</h1>
  </div>
  <section>
    <div class="wrap">
      <div class="held">
        <strong>Action needed:</strong> paste your existing Terms & Conditions text here (copy it from the current
        Wix site, or edit this file / the CMS "Pages" entry). The URL <code>/terms-conditions</code> is preserved,
        so all existing links and footer references keep working.
      </div>
      <div class="prose" style="margin-top:1.5rem">
        <p>&mdash; Terms & Conditions content goes here &mdash;</p>
      </div>
    </div>
  </section>
</Base>
