---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import HeroImage from '../../components/HeroImage.astro';
import Figure from '../../components/Figure.astro';
import YouTube from '../../components/YouTube.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((e) => e.data.published && e.data.series);
  const projects = await getCollection('research');
  return posts.map((entry) => {
    const key = entry.data.series;
    let source = { label: 'The Measured View', href: '/writing' };
    if (key === 'watt-workshops') source = { label: 'Watt Workshops', href: '/watt-workshops' };
    else {
      const proj = projects.find((p) => p.id === key);
      if (proj) source = { label: proj.data.title, href: `/research/${proj.id}` };
    }
    return { params: { slug: entry.id }, props: { entry, source } };
  });
}
const { entry, source } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const fmt = (x) => x.toISOString().slice(0, 10);
---
<Base title={`${d.title} | Blue Leaf Labs`} description={d.summary}>
  <div class="wrap detail">
    <a class="backlink" href={source.href}>← {source.label}</a>
    <header class="detail-head">
      <div class="kv"><span class="eyebrow">{d.tag}</span><span class="post-meta">{fmt(d.date)}{d.readingTime ? ` · ${d.readingTime}` : ''}</span></div>
      <h1>{d.title}</h1>
    </header>
    <HeroImage prefix={d.imagePrefix} alt={d.heroAlt} />
    <article class="prose serif"><Content components={{ Figure, YouTube }} /></article>
  </div>
</Base>
