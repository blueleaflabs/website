---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import Figure from '../../components/Figure.astro';
import YouTube from '../../components/YouTube.astro';
import VideoHero from '../../components/VideoHero.astro';

export async function getStaticPaths() {
  const items = (await getCollection('research')).filter((e) => e.data.published);
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const repoShort = d.repo ? d.repo.replace('https://github.com/', 'github.com/').replace(/\/$/, '') : null;
const pubs = (d.publications && d.publications.length)
  ? d.publications
  : (d.publicationUrl ? [{ url: d.publicationUrl, label: 'Published preprint' }] : []);
const shortenUrl = (u) => { const s = u.replace(/^https?:\/\//, ''); return s.startsWith('doi.org/') ? s : s.split('/')[0]; };

const gallery = d.gallery ?? [];
const galUrl = (src) => (/^(https?:)?\//.test(src) ? src : `/images/uploads/${src}`);
const awards = d.awards ?? [];
const hasAwards = awards.length > 0;
const hasPhotos = gallery.length > 0;
const hasTopBlock = (d.videos && d.videos.length > 0) || pubs.length > 0 || (d.highlights && d.highlights.length > 0) || hasAwards || hasPhotos;

const updates = (await getCollection('updates'))
  .filter((u) => u.data.published && u.data.project === entry.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const log = await Promise.all(updates.map(async (u) => ({
  id: u.id, data: u.data, Content: u.data.kind === 'post' ? null : (await render(u)).Content,
})));
const fmt = (x) => x.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title={`${d.title} | Blue Leaf Labs`} description={d.summary}>
  <div class="wrap detail">
    <a class="backlink" href="/research">← Research</a>

    <header class={`detail-head${hasTopBlock ? ' flush' : ''}`}>
      <div class="kv">
        <span class="eyebrow">{d.kind === 'analysis' ? 'Analysis' : 'Project'}</span>
        <span class={`status ${d.status.toLowerCase()}`}>{d.status}</span>
      </div>
      <h1>{d.title}</h1>
      {d.question && <p class="detail-summary">{d.question}</p>}
    </header>

    <VideoHero videos={d.videos} title={d.title} />

    {pubs.length > 0 && (
      <div class="pub">
        <span class="pub-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg></span>
        <div class="pub-txt">
          <span class="pub-lbl">{pubs.length > 1 ? 'Publications' : (pubs[0].label ?? 'Publication')}</span>
          {pubs.length === 1 ? (
            <a class="pub-doi" href={pubs[0].url}>{shortenUrl(pubs[0].url)} ↗</a>
          ) : (
            <div class="pub-list">
              {pubs.map((p) => (<a class="pub-item" href={p.url}>{p.label ?? shortenUrl(p.url)} ↗</a>))}
            </div>
          )}
        </div>
      </div>
    )}

    {d.highlights && d.highlights.length > 0 && (
      <div class="chips">
        {d.highlights.map((h) => (
          <span class="chip"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>{h}</span>
        ))}
      </div>
    )}

    {(hasAwards || hasPhotos) && (
      <div class="wins">
        <div class={hasAwards && hasPhotos ? 'wins-grid' : 'wins-solo'}>
          {hasAwards && (
            <div class="wins-awards">
              {awards.map((a) => (
                <div class="award">
                  <span class="tro"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h8M12 17v4M7 4h10v4a5 5 0 0 1-10 0V4zM5 4H4a2 2 0 0 0 0 4h1M19 4h1a2 2 0 0 1 0 4h-1"/></svg></span>
                  <div>
                    <div class="a-title">{a.title}</div>
                    {(a.venue || a.year) && <div class="a-meta">{[a.venue, a.year].filter(Boolean).join(' · ')}</div>}
                  </div>
                </div>
              ))}
            </div>
          )}
          {hasPhotos && (
            <div class="wins-photos">
              <div class="pg-grid">
                {gallery.map((g) => (
                  <figure>
                    <img src={galUrl(g.src)} alt={g.alt ?? g.caption ?? ''} loading="lazy" />
                    {g.caption && <figcaption>{g.caption}</figcaption>}
                  </figure>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    )}

    <div class="detail-grid">
      <div>
        <div class="prose"><Content components={{ Figure, YouTube }} /></div>

        {log.length > 0 && (
          <section class="project-log" aria-label="Project log">
            <h2>Project log</h2>
            <div class="log-list">
              {log.map((u) => {
                if (u.data.kind === 'post') {
                  return (
                    <a class="log-post" href={`/log/${u.id}`}>
                      <div class="log-date">{fmt(u.data.date)}</div>
                      <div class="log-title">{u.data.title}</div>
                      {u.data.summary && <p class="log-sum">{u.data.summary}</p>}
                      <span class="log-read">Read →</span>
                    </a>
                  );
                }
                const NoteBody = u.Content;
                return (
                  <div class="log-note">
                    <div class="log-date">{fmt(u.data.date)}</div>
                    <div class="log-title">{u.data.title}</div>
                    <div class="log-body prose"><NoteBody components={{ Figure, YouTube }} /></div>
                  </div>
                );
              })}
            </div>
          </section>
        )}
      </div>

      <aside class="glance" aria-label="Research at a glance">
        <h2>Research at a glance</h2>
        {d.methods && <div class="g-item"><div class="g-key">Primary methods</div><div class="g-val">{d.methods}</div></div>}
        {d.dataSources && <div class="g-item"><div class="g-key">Data sources</div><div class="g-val">{d.dataSources}</div></div>}
        {d.outputs && <div class="g-item"><div class="g-key">Outputs</div><div class="g-val">{d.outputs}</div></div>}
        {repoShort && <div class="g-item"><div class="g-key">Code</div><div class="g-val"><a href={d.repo}>{repoShort}</a></div></div>}
      </aside>
    </div>
  </div>
</Base>
