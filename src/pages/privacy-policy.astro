---
import Base from '../layouts/Base.astro';
---
<Base title="Privacy Policy | Blue Leaf Labs" description="Privacy Policy for Blue Leaf Labs.">
  <div class="wrap page-intro">
    <span class="eyebrow">Legal</span>
    <h1>Privacy Policy</h1>
  </div>
  <section>
    <div class="wrap">
      <div class="held">
        <strong>Action needed:</strong> paste your existing Privacy Policy text here (copy it from the current
        Wix site, or edit this file / the CMS "Pages" entry). The URL <code>/privacy-policy</code> is preserved,
        so all existing links and footer references keep working.
      </div>
      <div class="prose" style="margin-top:1.5rem">
        <p>&mdash; Privacy Policy content goes here &mdash;</p>
      </div>
    </div>
  </section>
</Base>
